    },
    "prepare_zip": {
      "name": "prepare_zip",
      "path": "./tools/prepare_zip.ts",
      "discovered": true,
      "shell_aliases": ["tool-prepare_zip"]
    }
  },
  "auto_reimport": {
    "apps": {
      "include": ["./apps/*"],
      "exclude": []
    },
    "tools": {
      "include": ["./tools/*"],
      "exclude": []
    }
  }
