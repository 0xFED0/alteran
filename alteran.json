{
  // Alteran project configuration.
  "name": "alteran",
  "auto_refresh_before_run": false,
  "shell_aliases": {},
  "deno_version": ">=2.4.1",
  "logging": {
    "stdout": {
      "mirror": true
    },
    "stderr": {
      "mirror": true
    },
    "logtape": false
  },
  "apps": {},
  "tools": {
    "prepare_jsr": {
      "name": "prepare_jsr",
