{
  "name": "multi-app-workspace",
  "auto_refresh_before_run": false,
  "deno_version": ">=2.4.1",
  "logging": {
    "stdout": {
      "mirror": true
    },
    "stderr": {
      "mirror": true
    },
    "logtape": false
  },
  "apps": {
    "hello-cli": {
      "name": "hello-cli",
      "path": "./apps/hello-cli",
      "discovered": true
    },
    "ops-report": {
      "name": "ops-report",
      "path": "./apps/ops-report",
      "discovered": true
    }
  },
  "tools": {},
  "auto_reimport": {
    "apps": {
      "include": [
        "./apps/*"
      ],
      "exclude": []
    },
    "tools": {
      "include": [
        "./tools/*"
      ],
      "exclude": []
    }
  }
}
